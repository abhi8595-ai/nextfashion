{
  "name": "nuxtcommerce",
  "version": "3.1.24",
  "private": true,
  "author": "weroza",
  "description": "Headless storefront for Woocommerce (Nuxt/Vue)",
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "dev:ssl": "nuxt dev --https --ssl-cert localhost.pem --ssl-key localhost-key.pem",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "build": "nuxt build",
    "start": "node .output/server/index.mjs"
  },
  "dependencies": {
    "@nuxt/image": "^1.11.0",
    "@nuxt/ui": "^2.22.3",
    "@nuxtjs/i18n": "10.1.0",
    "graphql-request": "^7.4.0",
    "notivue": "^2.4.5",
    "nuxt": "^4.4.2",
    "swiper": "^12.1.2",
    "vue": "latest",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@iconify-json/iconamoon": "^1.2.2",
    "@iconify-json/svg-spinners": "^1.2.4",
    "@types/node": "^25.9.3",
    "@vueuse/core": "^13.9.0",
    "@vueuse/nuxt": "^13.9.0",
    "vue-tsc": "^3.3.5"
  },
  "packageManager": "pnpm@11.7.0",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.7.0",
      "onFail": "warn"
    }
  },
  "overrides": {
    "vue-router": "^5.0.4"
  }
}